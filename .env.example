# Copy to .env and adjust as needed. Every variable already has a sensible,
# SECURE default baked into config/settings.py (DEBUG=False,
# ALLOWED_HOSTS=localhost-only), the two below are set here purely for a
# nicer *local dev* experience (pretty error pages) and are what you're
# opting INTO by copying this file, not what you get by default.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset to use local SQLite (zero setup). Set to switch to Postgres:
# docker-compose.yml sets this automatically for the `web` service:
# DATABASE_URL=postgres://fuelroute:fuelroute@db:5432/fuelroute

# Leave unset to use Django's in-memory cache. Set to enable Redis:
# docker-compose.yml sets this automatically for the `web` service:
# REDIS_URL=redis://redis:6379/0

# CORS: no origins are allowed by default. Uncomment ONE of these for a
# browser-based frontend to be able to call this API cross-origin.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://myfrontend.example.com
# CORS_ALLOW_ALL_ORIGINS=True

# Only relevant with DJANGO_DEBUG=False (see config/settings.py's production
# hardening block). Leave unset for docker-compose (plain HTTP, no TLS
# termination in front of it), turning SSL redirect on there would create
# an infinite redirect loop. Set both when deploying behind a real
# TLS-terminating proxy/load balancer (GCP Cloud Run, nginx, etc.):
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_BEHIND_PROXY=True
# DJANGO_SECURE_HSTS_SECONDS=31536000

# Vehicle assumptions used by the fuel-stop optimizer (see README "Assumptions").
VEHICLE_MPG=10
VEHICLE_RANGE_MILES=500
ROUTE_SEARCH_CORRIDOR_MILES=8

# Free, keyless external services.
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Nominatim's usage policy REQUIRES a real identifying User-Agent and can
# and does block generic/placeholder ones, the app will log a loud warning
# at startup of the first Nominatim call if you forget to set this.
NOMINATIM_USER_AGENT=fuel-route-planner-api (contact: you@example.com)

API_ANON_THROTTLE_RATE=60/min
